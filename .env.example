# CloudDash — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# --- LLM ---
GEMINI_API_KEY=your_gemini_api_key_here

# Model overrides (optional)
# GEMINI_MODEL=gemini-3.5-flash
# GEMINI_MODEL_DEFAULT=gemini-3.5-flash
# GEMINI_MODEL_TRIAGE=gemini-3.5-flash
# GEMINI_MODEL_TECHNICAL_SUPPORT=gemini-3.5-flash
# GEMINI_MODEL_BILLING=gemini-3.5-flash
# GEMINI_MODEL_ESCALATION=gemini-3.5-flash
# GEMINI_MODEL_QUERY_REWRITE=gemini-3.5-flash
# GEMINI_MODEL_LLM_JUDGE=gemini-3.5-flash

# --- Config override (optional) ---
# Uncomment to point the loader at a non-default config file.
# CLOUDDASH_CONFIG_PATH=config/agents_config.yaml

# --- Application ---
# Environment: development | staging | production
APP_ENV=development
LOG_LEVEL=INFO

# --- API Server ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Database (Stage 3) ---
# Defaults to a file-based SQLite DB in the project root.
DATABASE_URL=sqlite:///./clouddash.db
